{
  "name": "DevOps RCA Assessment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "postCreateCommand": "chmod +x ./submit && echo 'Environment ready! Open Cline to begin your investigation.'",
  "customizations": {
    "vscode": {
      "extensions": [
        "saoudrizwan.claude-dev"
      ],
      "settings": {
        "chat.disableAIFeatures": true,
        "files.exclude": {
          ".devcontainer": true,
          ".gitignore": true,
          ".github": true,
          ".clinerules": true,
          ".pytest_cache": true,
          "src": true,
          "build": true,
          "tests": true
        }
      }
    }
  }
}
